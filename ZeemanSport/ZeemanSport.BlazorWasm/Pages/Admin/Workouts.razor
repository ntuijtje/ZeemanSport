@page "/admin/workouts"
@using System.ComponentModel.DataAnnotations
@inject WorkoutApiClient WorkoutClient

<PageTitle>Workouts &mdash; ZeemanSport admin</PageTitle>

<div class="zs-section-title">
    <h1>Workouts</h1>
    <button class="btn btn-primary" @onclick="StartCreate">+ New workout</button>
</div>
<p class="text-muted">Manage the types of classes the club offers. Deleting a workout also removes its planned lessons.</p>

@if (_error != null)
{
    <div class="zs-alert zs-alert-error">@_error</div>
}

@if (_editing != null)
{
    <div class="zs-card mb-3">
        <h4>@(_editingId == null ? "New workout" : "Edit workout")</h4>
        <EditForm Model="_editing" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="zs-label">Name</label>
                    <InputText class="form-control" @bind-Value="_editing.Name" />
                    <ValidationMessage For="@(() => _editing.Name)" />
                </div>
                <div class="col-md-6">
                    <label class="zs-label">Description</label>
                    <InputText class="form-control" @bind-Value="_editing.Description" />
                </div>
                <div class="col-md-2 d-flex align-items-center">
                    <label class="zs-label mb-0">
                        <InputCheckbox @bind-Value="_editing.IsActive" /> Active
                    </label>
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Save</button>
                <button type="button" class="btn btn-outline-primary ms-2" @onclick="CancelEdit">Cancel</button>
            </div>
        </EditForm>
    </div>
}

@if (_workouts == null && _error == null)
{
    <p class="zs-empty">Loading&hellip;</p>
}
else if (_workouts != null)
{
    <table class="zs-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Status</th>
                <th style="width:160px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (WorkoutResponse workout in _workouts)
            {
                <tr>
                    <td><strong>@workout.Name</strong></td>
                    <td>@workout.Description</td>
                    <td>
                        @if (workout.IsActive)
                        {
                            <span class="zs-badge zs-badge-blue">Active</span>
                        }
                        else
                        {
                            <span class="zs-badge zs-badge-grey">Inactive</span>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" @onclick="@(() => StartEdit(workout))">Edit</button>
                        <button class="btn btn-sm btn-outline-danger ms-1" @onclick="@(() => DeleteAsync(workout))">Delete</button>
                    </td>
                </tr>
            }
            @if (_workouts.Count == 0)
            {
                <tr><td colspan="4" class="zs-empty">No workouts yet.</td></tr>
            }
        </tbody>
    </table>
}

@code {
    private IReadOnlyList<WorkoutResponse>? _workouts;
    private WorkoutModel? _editing;
    private int? _editingId;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _workouts = await WorkoutClient.GetAllAsync();
            _error = null;
        }
        catch (Exception exception)
        {
            _error = $"Could not reach the API. Is it running? ({exception.Message})";
        }
    }

    private void StartCreate()
    {
        _editingId = null;
        _editing = new WorkoutModel { IsActive = true };
    }

    private void StartEdit(WorkoutResponse workout)
    {
        _editingId = workout.Id;
        _editing = new WorkoutModel
        {
            Name = workout.Name,
            Description = workout.Description,
            IsActive = workout.IsActive
        };
    }

    private void CancelEdit()
    {
        _editing = null;
        _editingId = null;
    }

    private async Task SaveAsync()
    {
        if (_editing == null)
            return;

        try
        {
            if (_editingId == null)
            {
                await WorkoutClient.CreateAsync(new CreateWorkoutRequest
                {
                    Name = _editing.Name,
                    Description = _editing.Description
                });
            }
            else
            {
                await WorkoutClient.UpdateAsync(_editingId.Value, new UpdateWorkoutRequest
                {
                    Name = _editing.Name,
                    Description = _editing.Description,
                    IsActive = _editing.IsActive
                });
            }

            CancelEdit();
            await LoadAsync();
        }
        catch (Exception exception)
        {
            _error = $"Saving failed: {exception.Message}";
        }
    }

    private async Task DeleteAsync(WorkoutResponse workout)
    {
        try
        {
            await WorkoutClient.DeleteAsync(workout.Id);
            await LoadAsync();
        }
        catch (Exception exception)
        {
            _error = $"Delete failed: {exception.Message}";
        }
    }

    private class WorkoutModel
    {
        [Required]
        public string? Name { get; set; }
        public string? Description { get; set; }
        public bool IsActive { get; set; } = true;
    }
}
