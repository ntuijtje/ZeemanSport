@page "/"
@inject WorkoutApiClient WorkoutClient
@inject SubscriptionApiClient SubscriptionClient
@inject NavigationManager Navigation

<PageTitle>ZeemanSport Sportclub</PageTitle>

<section class="zs-hero">
    <img src="images/logo.png" alt="ZeemanSport" />
    <div>
        <h1>Welcome to ZeemanSport</h1>
        <p>
            Group lessons, bootcamp, boxing and spinning &mdash; all under one roof. Browse our
            classes, pick the subscription that fits you and start training today.
        </p>
        <button class="btn btn-accent btn-lg" @onclick="@(() => Navigation.NavigateTo("signup"))">
            Become a member
        </button>
        <button class="btn btn-outline-light btn-lg ms-2" @onclick="@(() => Navigation.NavigateTo("schedule"))">
            View lessons
        </button>
    </div>
</section>

<div class="zs-section-title">
    <h2>Our classes</h2>
    <a class="btn btn-outline-primary" href="schedule">See the full schedule</a>
</div>

@if (_loadError != null)
{
    <div class="zs-alert zs-alert-error">@_loadError</div>
}
else if (_workouts == null)
{
    <p class="zs-empty">Loading classes&hellip;</p>
}
else if (_workouts.Count == 0)
{
    <p class="zs-empty">No classes have been published yet.</p>
}
else
{
    <div class="row g-3">
        @foreach (WorkoutResponse workout in _workouts)
        {
            <div class="col-md-6 col-lg-4">
                <div class="zs-card h-100">
                    <h4>@workout.Name</h4>
                    <p class="text-muted mb-0">
                        @(string.IsNullOrWhiteSpace(workout.Description) ? "A great way to stay fit." : workout.Description)
                    </p>
                </div>
            </div>
        }
    </div>
}

<div class="zs-section-title mt-5">
    <h2>Membership</h2>
    <a class="btn btn-outline-primary" href="subscriptions">Compare subscriptions</a>
</div>

@if (_plans != null && _plans.Count > 0)
{
    <div class="row g-3">
        @foreach (SubscriptionPlanResponse plan in _plans)
        {
            <div class="col-sm-6 col-lg-3">
                <div class="zs-plan">
                    <div class="zs-badge zs-badge-blue mb-2">@plan.AccessTier</div>
                    <div class="zs-price">&euro;@plan.Price.ToString("0.##")
                        <small>/ @(plan.BillingInterval == BillingInterval.Monthly ? "month" : "year")</small>
                    </div>
                    <p class="text-muted mt-2 mb-0">@plan.Name</p>
                </div>
            </div>
        }
    </div>
}

@code {
    private IReadOnlyList<WorkoutResponse>? _workouts;
    private IReadOnlyList<SubscriptionPlanResponse>? _plans;
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _workouts = await WorkoutClient.GetAllAsync();
            _plans = await SubscriptionClient.GetPlansAsync();
        }
        catch (Exception exception)
        {
            _loadError = $"Could not reach the ZeemanSport API. Is it running? ({exception.Message})";
        }
    }
}
